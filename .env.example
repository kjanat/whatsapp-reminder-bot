# WhatsApp Business API credentials
WHATSAPP_API_URL=https://graph.facebook.com/v22.0/your_phone_number_id/messages
WHATSAPP_API_TOKEN=your_access_token_here

# Phone number (optional for testing purposes)
PHONE_NUMBER=31612345678

# Server configuration
PORT=3000

# Reminder messages
REMINDER_MESSAGE="Tijd voor insuline!"
FOLLOW_UP_MESSAGE="Vergeet niet om te reageren met '✅' als je de insuline hebt genomen!"

# Template ID for WhatsApp message
TEMPLATE_ID=event_details_example_1
